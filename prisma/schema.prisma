// revisi


generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum adminRole {
  ADMIN
}

model Admin {
  id_admin   Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  role       adminRole
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

}
// master
model User {
  id_user    Int      @id @default(autoincrement())
  name       String
  jabatan    String?
  no_hp      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  borrowed_assets AssetBorrowed[]
  //asset_logs     AssetLogs[]
}

model AssetCategories {
  id_asset_categories Int @id @default(autoincrement())
  name        String
  description String?

  assets Asset[]
}

model AssetTypes {
  id_asset_types Int @id @default(autoincrement())
  name        String
  description String?

  assets Asset[]
}

model Asset {
  id_assets           Int @id @default(autoincrement())
  id_asset_categories Int
  id_asset_types      Int
  asset_code          String  @unique
  asset_name          String
  purchase_price      Float?
  is_rentable         Boolean @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  category AssetCategories @relation(fields: [id_asset_categories], references: [id_asset_categories])
  type     AssetTypes      @relation(fields: [id_asset_types], references: [id_asset_types])

  stocks       AssetStock[]
  //logs         AssetLogs[]
}

enum AssetCondition {
  BAIK
  RUSAK
}

enum AssetStockStatus {
  TERSEDIA
  TIDAK_TERSEDIA
  MAINTENANCE
  DIPINJAM
  DIPAKAI
  DISEWA
}


model AssetStock {
  id_asset_stock Int @id @default(autoincrement())
  id_asset       Int
  id_location    Int

  condition AssetCondition
  status    AssetStockStatus
  quantity  Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  asset    Asset    @relation(fields: [id_asset], references: [id_assets])
  location Location @relation(fields: [id_location], references: [id_location])


  borrowed     AssetBorrowed[]      // this
  maintenance  AssetMaintenance[]   // DAN this
  rentals      AssetRental[]
  @@unique([id_asset, id_location,condition,status])
  // @@unique([id_asset, id_location, condition, status])

}


model Location {
  id_location Int @id @default(autoincrement())
  name        String
  description String?

  stocks       AssetStock[]
}

enum BorrowStatus {
  DIPAKAI
  DIPINJAM
  DIKEMBALIKAN
  TERLAMBAT
}
//asset assignment
model AssetBorrowed {
  id_asset_borrowed Int @id @default(autoincrement())
  id_asset_stock    Int
  id_user           Int?
  quantity          Int
  borrowed_date     DateTime  @default(now())
  returned_date     DateTime  @updatedAt
  status            BorrowStatus

  assetStock AssetStock @relation(fields: [id_asset_stock], references: [id_asset_stock])
  user  User?  @relation(fields: [id_user], references: [id_user])

}

model RentalCustomer {
  id_rental_customer Int @id @default(autoincrement())
  name    String
  phone   String?
  email   String?
  address String?
 
  created_at DateTime @default(now())

  rentals AssetRental[]
}
enum RentalStatus {
  AKTIF
  SELESAI
  DIBATALKAN
}

model AssetRental {
  id_asset_rental     Int @id @default(autoincrement())
  id_rental_customer  Int
  id_asset_stock      Int
  quantity            Int
  fotoKtp            String
  rental_start        DateTime
  rental_end          DateTime
  price               Float
  status              RentalStatus

  assetStock AssetStock     @relation(fields: [id_asset_stock], references: [id_asset_stock])
  customer RentalCustomer @relation(fields: [id_rental_customer], references: [id_rental_customer])
}
//history purpose
model AssetLogs {
  id_asset_logs Int @id @default(autoincrement())
  action        String
  description   String?
  created_at    DateTime @default(now())
}

enum MaintenanceStatus {
  ON_PROGRESS
  DONE
}

model AssetMaintenance {
  id_asset_maintenance    Int @id @default(autoincrement())
  id_asset_stock   Int
  created_at       DateTime @default(now())
  description      String?
  cost             Float?
  quantity         Int
  updated_at       DateTime @updatedAt
  status           MaintenanceStatus @default(ON_PROGRESS)
  assetStock AssetStock @relation(fields: [id_asset_stock], references: [id_asset_stock])
}

model BlacklistedToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiredAt DateTime
  createdAt DateTime @default(now())
}

